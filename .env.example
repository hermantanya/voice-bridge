# Copy to server/.env and fill in real values. NEVER commit server/.env.

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Server port (Railway sets PORT automatically)
PORT=3001

# Comma-separated allowed origins for CORS/WebSocket, or * for dev
CLIENT_ORIGIN=*

# Rate limits (protect OpenAI credits if the repo/server is public)
RATE_LIMIT_TRANSLATE_PER_HOUR=30
RATE_LIMIT_AUDIO_PER_HOUR=120
RATE_LIMIT_JOIN_PER_MINUTE=20
